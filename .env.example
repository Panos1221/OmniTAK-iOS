# OmniTAK-iOS build-time environment variables.
# Copy to .env (which is gitignored) and set values before building.
# These are read by Xcode's variable substitution into Info.plist.

# Optional: default password used as a fallback when extracting
# certificates from imported TAK data packages. Most public TAK servers
# use the well-known default "atakatak". Leave blank for none.
DEFAULT_P12_PASSWORD=
